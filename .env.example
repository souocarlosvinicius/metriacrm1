# NODE_ENV: Define o ambiente de execução da aplicação (development ou production)
NODE_ENV=development

# APP_URL: A URL base onde o frontend está rodando (usado para links absolutos e redirecionamentos)
APP_URL=http://localhost:3000

# PORT: A porta na qual o servidor Node/Express irá escutar as requisições HTTP
PORT=3000

# GEMINI_API_KEY: Chave da API do Google Gemini para recursos inteligentes de geração de descrição e Next Best Actions
GEMINI_API_KEY=

# SUPABASE: Configurações de conexão para o banco de dados, autenticação e storage do Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
